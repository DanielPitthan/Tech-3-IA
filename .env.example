# Chaves de API (copie para .env e preencha)

# HuggingFace Token (para download de modelos gated)
HF_TOKEN=your_hf_token_here

# OpenAI API Key (usado apenas para LLM-as-judge na avaliação)
OPENAI_API_KEY=sk-your_key_here

# Modelo base para fine-tuning
BASE_MODEL_NAME=tiiuae/falcon-7b-instruct

# Diretório de saída do modelo fine-tunado
OUTPUT_MODEL_DIR=./models/falcon-7b-medical

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
